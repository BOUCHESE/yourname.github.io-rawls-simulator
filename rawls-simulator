      return `
        <div class="map">
          <div class="road road-h" style="left:10%; top:40%; width:76%;"></div>
          <div class="road road-h" style="left:14%; top:65%; width:64%;"></div>
          <div class="road road-v" style="left:29%; top:19%; height:58%;"></div>
