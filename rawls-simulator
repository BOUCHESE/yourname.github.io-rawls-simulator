<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Veil of Ignorance RPG</title>
  <style>
    :root {
      --bg: #08111f;
      --panel: rgba(13, 24, 43, 0.94);
      --panel-2: rgba(19, 35, 63, 0.94);
      --line: rgba(133, 164, 255, 0.18);
      --text: #f2f7ff;
      --muted: #9fb5df;
      --accent: #88a9ff;
      --accent-2: #68f0c1;
      --danger: #ff7a9f;
      --gold: #ffd76a;
      --shadow: 0 22px 60px rgba(0, 0, 0, 0.35);
      --radius: 22px;
    }

    * { box-sizing: border-box; }

    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(115, 139, 255, 0.18), transparent 28%),
        radial-gradient(circle at top right, rgba(45, 211, 191, 0.14), transparent 24%),
        linear-gradient(180deg, #09111f 0%, #0b1323 46%, #071019 100%);
      color: var(--text);
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
      background-size: 22px 22px;
      pointer-events: none;
      opacity: 0.35;
    }

    #app {
      width: 100%;
      height: 100%;
      padding: 14px;
    }

    .shell {
      width: 100%;
      height: calc(100vh - 28px);
      border: 1px solid var(--line);
      border-radius: 28px;
      background: rgba(7, 14, 27, 0.72);
      box-shadow: var(--shadow);
      overflow: hidden;
      position: relative;
    }

    .shell::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, rgba(255,255,255,0.05), transparent 20%, transparent 80%, rgba(255,255,255,0.03));
      pointer-events: none;
    }

    .screen {
      position: absolute;
      inset: 0;
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }

    .glass {
      background: linear-gradient(180deg, rgba(17, 31, 56, 0.94), rgba(11, 20, 38, 0.94));
    }

    .title-screen {
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 14px;
      height: 100%;
    }

    .hero-panel {
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      position: relative;
      overflow: hidden;
      min-height: 0;
    }

    .hero-panel::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 18% 24%, rgba(114, 141, 255, 0.22), transparent 30%),
        radial-gradient(circle at 80% 20%, rgba(64, 238, 196, 0.16), transparent 24%),
        linear-gradient(180deg, rgba(255,255,255,0.03), transparent 40%);
      pointer-events: none;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 12px;
      border-radius: 999px;
      background: rgba(136, 169, 255, 0.12);
      color: #d6e2ff;
      border: 1px solid rgba(136, 169, 255, 0.18);
      font-size: 12px;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      width: fit-content;
    }

    h1, h2, h3, h4, p { margin: 0; }

    h1 {
      font-size: clamp(34px, 4vw, 58px);
      line-height: 0.95;
      letter-spacing: -0.04em;
      max-width: 10ch;
    }

    .lead {
      color: #dce7ff;
      font-size: 18px;
      line-height: 1.45;
      max-width: 55ch;
    }

    .muted { color: var(--muted); }

    .title-bottom {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 14px;
      position: relative;
      z-index: 1;
    }

    .mini-card {
      padding: 14px;
      border-radius: 18px;
      border: 1px solid var(--line);
      background: rgba(11, 20, 37, 0.72);
    }

    .title-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
      margin-top: 18px;
      position: relative;
      z-index: 1;
    }

    button {
      border: none;
      cursor: pointer;
      color: var(--text);
      transition: transform 0.15s ease, opacity 0.2s ease, border-color 0.2s ease, background 0.2s ease;
      font: inherit;
    }

    .btn {
      min-height: 46px;
      padding: 12px 16px;
      border-radius: 16px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.08);
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      font-weight: 700;
    }

    .btn:hover { transform: translateY(-1px); }

    .btn-primary {
      background: linear-gradient(135deg, rgba(136,169,255,0.96), rgba(96,227,201,0.82));
      color: #07111d;
      border: none;
    }

    .btn-secondary {
      background: rgba(136, 169, 255, 0.14);
      color: #dce7ff;
      border: 1px solid rgba(136, 169, 255, 0.26);
    }

    .preview-panel {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 0;
    }

    .pill-row, .tag-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .pill, .tag {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 8px 11px;
      border-radius: 999px;
      background: rgba(255,255,255,0.05);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 12px;
      color: #d3e1ff;
    }

    .title-metrics {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .score-box {
      padding: 14px;
      border-radius: 18px;
      background: rgba(9, 18, 34, 0.85);
      border: 1px solid var(--line);
    }

    .big-score {
      font-size: 42px;
      letter-spacing: -0.05em;
      margin-top: 6px;
      font-weight: 800;
    }

    .builder-layout {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 14px;
      height: 100%;
      min-height: 0;
    }

    .builder-left {
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 14px;
      min-height: 0;
    }

    .builder-header {
      padding: 18px 20px;
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 16px;
    }

    .builder-header h2 { font-size: 30px; letter-spacing: -0.03em; }

    .subtle-note {
      font-size: 13px;
      color: var(--muted);
      line-height: 1.45;
      max-width: 46ch;
    }

    .world-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      overflow: auto;
      padding-right: 4px;
      min-height: 0;
    }

    .config-card {
      padding: 16px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      min-height: 132px;
    }

    .config-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .config-title {
      font-size: 16px;
      font-weight: 700;
    }

    .config-value {
      font-size: 12px;
      color: #d4e2ff;
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(136, 169, 255, 0.16);
      border: 1px solid rgba(136, 169, 255, 0.22);
    }

    .option-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .toggle {
      padding: 8px 10px;
      border-radius: 12px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      color: #dce7ff;
      font-size: 12px;
      min-height: 38px;
    }

    .toggle.active {
      background: rgba(136, 169, 255, 0.2);
      border-color: rgba(136, 169, 255, 0.45);
      color: white;
      box-shadow: 0 0 0 1px rgba(136, 169, 255, 0.12) inset;
    }

    .config-desc {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.42;
    }

    .builder-right {
      display: grid;
      grid-template-rows: auto auto 1fr auto;
      gap: 14px;
      min-height: 0;
    }

    .preview-stack {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 0;
    }

    .bar-block { display: flex; flex-direction: column; gap: 8px; }

    .bar-label {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      font-size: 13px;
      color: #dbe6ff;
    }

    .bar-shell {
      width: 100%;
      height: 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.06);
    }

    .bar-fill {
      height: 100%;
      border-radius: 999px;
      background: linear-gradient(90deg, rgba(136,169,255,0.9), rgba(104,240,193,0.95));
      width: 0%;
      transition: width 360ms ease;
    }

    .map-card {
      padding: 14px;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .map {
      position: relative;
      flex: 1;
      min-height: 248px;
      border-radius: 22px;
      overflow: hidden;
      border: 1px solid rgba(255,255,255,0.08);
      background:
        linear-gradient(180deg, #3b6be8 0%, #7ccfff 27%, #8fe2b9 27%, #7bc56a 54%, #4a814c 54%, #2d4e3a 100%);
      box-shadow: inset 0 20px 40px rgba(255,255,255,0.08), inset 0 -18px 22px rgba(0,0,0,0.18);
    }

    .map::before {
      content: "";
      position: absolute;
      inset: 0;
      background-image:
        linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px);
      background-size: 18px 18px;
      opacity: 0.3;
      pointer-events: none;
    }

    .road {
      position: absolute;
      background: rgba(33, 42, 56, 0.7);
      border: 1px solid rgba(255,255,255,0.08);
      box-shadow: inset 0 0 0 1px rgba(0,0,0,0.12);
    }

    .road-h { height: 18px; border-radius: 9px; }
    .road-v { width: 18px; border-radius: 9px; }

    .building {
      position: absolute;
      width: 74px;
      padding: 10px 8px;
      border-radius: 18px;
      border: 1px solid rgba(9, 18, 28, 0.18);
      background: rgba(244, 249, 255, 0.92);
      color: #07111d;
      text-align: center;
      font-size: 11px;
      line-height: 1.15;
      box-shadow: 0 10px 22px rgba(0,0,0,0.18);
      transform: translate(-50%, -50%);
    }

    .building strong { display: block; font-size: 16px; margin-bottom: 4px; }
    .building.active { outline: 3px solid rgba(255, 215, 106, 0.8); }

    .hero {
      position: absolute;
      transform: translate(-50%, -50%);
      transition: left 420ms ease, top 420ms ease;
      z-index: 2;
      animation: bob 1.4s infinite ease-in-out;
      filter: drop-shadow(0 10px 12px rgba(0,0,0,0.28));
    }

    @keyframes bob {
      0%, 100% { transform: translate(-50%, -50%); }
      50% { transform: translate(-50%, calc(-50% - 5px)); }
    }

    .pixel {
      display: grid;
      grid-template-columns: repeat(6, 8px);
      grid-template-rows: repeat(7, 8px);
      gap: 1px;
      padding: 5px;
      border-radius: 14px;
      background: rgba(9, 18, 34, 0.3);
      backdrop-filter: blur(3px);
    }

    .px { width: 8px; height: 8px; background: transparent; }
    .hair { background: #162033; }
    .skin { background: #f2c18b; }
    .shirt { background: #6d84ff; }
    .pants { background: #26334e; }
    .shoe { background: #111821; }
    .spark { background: #ffd76a; }

    .birth-layout, .ending-layout {
      display: grid;
      grid-template-columns: 1fr 0.9fr;
      gap: 14px;
      height: 100%;
      min-height: 0;
    }

    .birth-left, .ending-left {
      padding: 20px;
      display: flex;
      flex-direction: column;
      gap: 14px;
      min-height: 0;
    }

    .birth-name {
      font-size: 40px;
      letter-spacing: -0.05em;
      line-height: 0.95;
    }

    .birth-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .info-chip {
      padding: 13px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.07);
    }

    .info-chip small { color: var(--muted); display: block; margin-bottom: 6px; }

    .play-layout {
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 12px;
      height: 100%;
      min-height: 0;
    }

    .hud {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr 1fr;
      gap: 12px;
    }

    .hud-card {
      padding: 14px 16px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 10px;
      min-height: 0;
    }

    .hud-value {
      font-size: 26px;
      letter-spacing: -0.04em;
      font-weight: 800;
    }

    .main-grid {
      display: grid;
      grid-template-columns: 0.95fr 0.9fr 1.15fr;
      gap: 12px;
      min-height: 0;
      height: 100%;
    }

    .column {
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .panel {
      padding: 14px;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
      overflow: hidden;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      overflow: auto;
      padding-right: 4px;
      min-height: 0;
    }

    .metric {
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .metric-head {
      display: flex;
      justify-content: space-between;
      gap: 8px;
      align-items: center;
      font-size: 13px;
      color: #d8e4ff;
    }

    .metric strong {
      font-size: 18px;
      letter-spacing: -0.03em;
      color: white;
    }

    .history-list {
      display: flex;
      flex-direction: column;
      gap: 8px;
      overflow: auto;
      padding-right: 4px;
      min-height: 0;
    }

    .history-item {
      padding: 12px;
      border-radius: 16px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.05);
      font-size: 13px;
      line-height: 1.45;
      color: #d7e3ff;
    }

    .history-item small {
      display: block;
      color: var(--muted);
      margin-bottom: 6px;
    }

    .decision-card {
      padding: 16px;
      min-height: 0;
      display: flex;
      flex-direction: column;
      gap: 12px;
      overflow: hidden;
    }

    .decision-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .stage-tag {
      padding: 7px 10px;
      border-radius: 999px;
      background: rgba(104, 240, 193, 0.12);
      color: #d7fff3;
      border: 1px solid rgba(104, 240, 193, 0.2);
      font-size: 12px;
    }

    .npc-box {
      padding: 12px 13px;
      border-radius: 16px;
      background: rgba(136, 169, 255, 0.08);
      border: 1px solid rgba(136, 169, 255, 0.14);
      color: #dce7ff;
      font-size: 13px;
      line-height: 1.45;
    }

    .options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      overflow: auto;
      padding-right: 4px;
      min-height: 0;
    }

    .option {
      padding: 13px;
      border-radius: 18px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      display: flex;
      flex-direction: column;
      gap: 10px;
      min-height: 188px;
      text-align: left;
    }

    .option:hover { border-color: rgba(136,169,255,0.35); }
    .option.locked {
      opacity: 0.5;
      cursor: not-allowed;
      border-style: dashed;
    }

    .option-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 10px;
    }

    .option-title {
      font-size: 15px;
      font-weight: 800;
      line-height: 1.25;
      color: white;
    }

    .chance {
      padding: 7px 9px;
      border-radius: 999px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.06);
      font-size: 11px;
      color: #dbe6ff;
      white-space: nowrap;
    }

    .impact-row {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: auto;
    }

    .impact {
      padding: 6px 8px;
      border-radius: 999px;
      font-size: 11px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.06);
      color: #dbe6ff;
    }

    .impact.up { color: #c8fff0; border-color: rgba(104, 240, 193, 0.22); background: rgba(104, 240, 193, 0.12); }
    .impact.down { color: #ffd3df; border-color: rgba(255, 122, 159, 0.24); background: rgba(255, 122, 159, 0.12); }

    .lock-note {
      margin-top: auto;
      font-size: 12px;
      color: #ffd6df;
      display: flex;
      gap: 8px;
      align-items: flex-start;
      line-height: 1.35;
    }

    .progress-wrap {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .ending-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .ending-title {
      font-size: 42px;
      letter-spacing: -0.05em;
      line-height: 0.95;
      max-width: 12ch;
    }

    .reflection {
      padding: 16px;
      border-radius: 18px;
      background: rgba(136, 169, 255, 0.08);
      border: 1px solid rgba(136, 169, 255, 0.18);
      line-height: 1.55;
      color: #e6efff;
    }

    .list {
      display: flex;
      flex-direction: column;
      gap: 10px;
      color: #dbe6ff;
      font-size: 14px;
    }

    .list div {
      padding: 12px;
      border-radius: 14px;
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.06);
    }

    .footer-actions {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-top: auto;
    }

    @media (max-width: 1240px) {
      .title-screen, .builder-layout, .birth-layout, .ending-layout { grid-template-columns: 1fr; }
      .main-grid { grid-template-columns: 1fr; }
      .hud { grid-template-columns: 1fr; }
      .options, .world-grid, .metrics-grid, .birth-grid, .ending-grid, .title-metrics { grid-template-columns: 1fr; }
      .shell { overflow: auto; }
      html, body { overflow: auto; }
      #app { height: auto; }
      .screen { position: relative; min-height: 100vh; }
    }
  </style>
</head>
<body>
  <div id="app"></div>
  <script>
    const TAX_LEVELS = [
      { label: "0% tax", desc: "Pure turbo-capitalism. Your wallet stays full, public systems do not." },
      { label: "10% tax", desc: "Minimal state. Cheap to earn, expensive to fall." },
      { label: "20% tax", desc: "Lean government with patchy safety nets." },
      { label: "30% tax", desc: "Basic public services begin to matter." },
      { label: "40% tax", desc: "Balanced model with visible redistribution." },
      { label: "50% tax", desc: "Strong public investment and moderate private upside." },
      { label: "60% tax", desc: "Heavy redistribution. Risk-taking slows, floors rise." },
      { label: "70% tax", desc: "High social guarantee, lower private accumulation." },
      { label: "80% tax", desc: "Very compressed inequality. Elite upside is constrained." },
      { label: "90% tax", desc: "Almost fully collective model. Extreme private wealth is nearly impossible." }
    ];

    const EDUCATION_LEVELS = [
      { label: "Tier 1: Bare minimum", desc: "Underfunded schools, lucky kids carry themselves." },
      { label: "Tier 2: Uneven", desc: "Some strong schools, many weak ones." },
      { label: "Tier 3: Competent", desc: "Reliable public education with solid mobility." },
      { label: "Tier 4: Strong", desc: "High-quality schooling, tutoring, libraries, career tracks." },
      { label: "Tier 5: Elite public system", desc: "World-class universal education." }
    ];

    const HEALTHCARE_LEVELS = [
      { label: "Tier 1: Market only", desc: "Care exists, but mainly for people who can pay." },
      { label: "Tier 2: Patchy coverage", desc: "Clinics help, bills still wreck families." },
      { label: "Tier 3: Basic coverage", desc: "You usually get treated before things spiral." },
      { label: "Tier 4: Strong coverage", desc: "Preventive care and mental health are real." },
      { label: "Tier 5: Universal care", desc: "Illness rarely means financial collapse." }
    ];

    const WELFARE_LEVELS = [
      { label: "Level 1: Survival only", desc: "Miss one paycheck and gravity wins." },
      { label: "Level 2: Thin cushion", desc: "Temporary help, lots of paperwork, limited dignity." },
      { label: "Level 3: Real safety net", desc: "Bad luck hurts, but does not automatically destroy you." },
      { label: "Level 4: Strong floor", desc: "The system actively prevents freefall." }
    ];

    const HOUSING_LEVELS = [
