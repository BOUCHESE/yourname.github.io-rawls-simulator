    const state = createInitialState();
    const app = document.getElementById("app");

    function createInitialState() {
      return {
        scene: "title",
        env: { tax: 4, education: 2, healthcare: 2, welfare: 1, housing: 2, labor: 2, policing: 2 },
        player: null,
        stats: null,
        flags: {},
        eventIndex: 0,
        history: [],
        lastResult: null,
        fairness: null,
        spawn: null,
        ending: null
      };
    }

    function resetGame() {
      const fresh = createInitialState();
      Object.keys(state).forEach((key) => delete state[key]);
      Object.assign(state, fresh);
      render();
    }

    function clamp(value, min, max) {
      return Math.max(min, Math.min(max, value));
    }

    function money(n) {
      return new Intl.NumberFormat("en-US", { style: "currency", currency: "USD", maximumFractionDigits: 0 }).format(Math.round(n));
    }

    function scorePercent(value, max) {
      return clamp((value / max) * 100, 0, 100);
    }

    function metricValue(key, value) {
      const meta = METRICS[key];
      return meta.kind === "money" ? money(value) : Math.round(value);
    }

    function bandFromPercentile(p) {
      if (p >= 95) return "Top 5%";
      if (p >= 80) return "Top 20%";
      if (p >= 60) return "Upper-middle 40%";
      if (p >= 40) return "Middle band";
      if (p >= 20) return "Lower 40%";
      return "Bottom 20%";
    }

    function computeSociety(env) {
      const fairness = clamp(28 + env.tax * 5 + env.welfare * 10 + (4 - env.housing) * 6 + env.education * 7 + env.healthcare * 6 + env.labor * 5 - env.policing * 2, 0, 100);
      const opportunity = clamp(22 + env.education * 11 + env.healthcare * 5 + env.labor * 6 + (4 - env.housing) * 3 + (9 - env.tax) * 2, 0, 100);
      const safety = clamp(18 + env.healthcare * 11 + env.welfare * 12 + (4 - env.housing) * 4 + env.policing * 8, 0, 100);
      const volatility = clamp(64 + env.housing * 8 + (9 - env.tax) * 3 - env.welfare * 10 - env.healthcare * 5 - env.labor * 5, 0, 100);
      const assetAccess = clamp(20 + env.housing * 12 + (9 - env.tax) * 4 - env.welfare * 4 + env.labor * 2, 0, 100);
      const overall = Math.round((fairness + opportunity + safety + (100 - volatility) + assetAccess) / 5);
      return { fairness, opportunity, safety, volatility, assetAccess, overall };
    }

    function randomFrom(list) {
      return list[Math.floor(Math.random() * list.length)];
    }

    function spawnPlayer() {
      const society = computeSociety(state.env);
      const city = randomFrom(CITIES);
      const first = randomFrom(FIRST_NAMES);
      const last = randomFrom(LAST_NAMES);
      const roll = Math.random() * 100;
      const birthPercentile = clamp(Math.round(roll + state.env.housing * 6 + (9 - state.env.tax) * 2 - state.env.welfare * 6 - state.env.education * 3 - state.env.healthcare * 2), 1, 99);
      const band = bandFromPercentile(birthPercentile);
      const baseBank = birthPercentile > 90 ? 12000 : birthPercentile > 70 ? 4500 : birthPercentile > 45 ? 900 : 150;
      const baseAssets = birthPercentile > 88 ? 18000 : birthPercentile > 65 ? 2500 : 0;
      const housing = clamp(30 + (4 - state.env.housing) * 8 + birthPercentile * 0.18 - state.env.housing * (birthPercentile < 40 ? 4 : 0), 0, 100);
      const stats = {
        bank: Math.round(baseBank + state.env.welfare * 240 - state.env.housing * 100),
        health: clamp(38 + state.env.healthcare * 11 + state.env.welfare * 6 + Math.random() * 12 - (100 - birthPercentile) * 0.08, 0, 100),
        education: clamp(16 + state.env.education * 14 + birthPercentile * 0.24 + Math.random() * 6, 0, 100),
        happiness: clamp(44 + state.env.welfare * 5 + (4 - state.env.housing) * 2 + Math.random() * 10, 0, 100),
        housing,
        assets: Math.round(baseAssets),
        debt: 0,
        social: clamp(26 + state.env.welfare * 4 + Math.random() * 20, 0, 100),
        stress: clamp(32 + state.env.policing * 4 + state.env.housing * 4 - state.env.healthcare * 4 - state.env.welfare * 6 + (50 - birthPercentile) * 0.18, 0, 100),
        power: clamp(8 + birthPercentile * 0.42 + state.env.education * 3 + state.env.labor * 2 - state.env.policing, 0, 100)
      };

      state.player = {
        name: first + " " + last,
        place: city.place,
        country: city.country,
        percentile: birthPercentile,
        band,
        archetype: birthPercentile > 85 ? "born near the top of the map" : birthPercentile > 50 ? "born into the unstable middle" : "born close to the floor"
      };
      state.stats = stats;
      state.fairness = society;
      state.spawn = {
        headline: state.player.name + " spawns in " + city.place + ", " + city.country,
        subhead: "You built the rules first. Only now do you learn where you landed."
      };
      state.flags = {};
      state.eventIndex = 0;
      state.history = [
        {
          age: 0,
          title: "Birth Reveal",
          text: state.player.name + " enters the world in " + city.place + ", " + city.country + ". The system places you in the " + band + "."
        }
      ];
      state.lastResult = null;
      state.ending = null;
    }

    function currentEvent() {
      return EVENTS[state.eventIndex];
    }

    function optionLocked(option) {
      if (option.envReq) {
        const [key, min] = Object.entries(option.envReq)[0];
        if (state.env[key] < min) return option.lock || "Environment requirement not met.";
      }
      if (option.forbidEnv) {
        const [key, maxSafe] = Object.entries(option.forbidEnv)[0];
        if (state.env[key] >= maxSafe) return option.lock || "Environment blocks this choice.";
      }
      if (option.statReq) {
        const [key, min] = Object.entries(option.statReq)[0];
        if (state.stats[key] < min) return option.lock || "Your stats are too low.";
      }
      if (option.flagsReq) {
        const missing = option.flagsReq.find((flag) => !state.flags[flag]);
        if (missing) return option.lock || "This route was not unlocked earlier.";
      }
      if (option.forbidFlags) {
        const blocked = option.forbidFlags.find((flag) => state.flags[flag]);
        if (blocked) return option.lock || "A past choice blocks this option.";
      }
      return null;
    }

    function adjustedChance(baseChance) {
      const s = state.stats;
      const bonus = (s.education - 50) / 250 + (s.social - 50) / 280 + (s.power - 40) / 320 + Math.max(0, s.bank) / 70000 + state.fairness.opportunity / 500 - s.stress / 500 - s.debt / 90000;
      return clamp(baseChance + bonus, 0.15, 0.97);
    }

    function applyEffects(effects) {
      Object.entries(effects).forEach(([key, delta]) => {
        if (METRICS[key].kind === "money") {
          state.stats[key] = Math.round(state.stats[key] + delta);
        } else {
          state.stats[key] = clamp(state.stats[key] + delta, 0, 100);
        }
      });
      state.stats.bank = Math.round(state.stats.bank);
      state.stats.assets = Math.round(Math.max(0, state.stats.assets));
      state.stats.debt = Math.round(Math.max(0, state.stats.debt));
    }

    function applyFlags(list, value) {
      (list || []).forEach((flag) => { state.flags[flag] = value; });
    }

    function chooseOption(index) {
      const event = currentEvent();
      const option = event.options[index];
      const lockedReason = optionLocked(option);
      if (lockedReason) return;
      const chance = adjustedChance(option.chance || 1);
      const success = Math.random() < chance;
      const outcome = success ? option.effects : (option.fail || option.effects);
      applyEffects(outcome);
      applyFlags(option.addFlags, true);
      applyFlags(option.removeFlags, false);
      if (!success && option.failAddFlags) applyFlags(option.failAddFlags, true);

      state.lastResult = {
        success,
        chance,
        title: option.label,
        text: success ? "The move lands." : "The move partly fails. The world pushes back."
      };

      state.history.unshift({
        age: event.age,
        title: event.title,
        text: (success ? "Success: " : "Setback: ") + option.label + ". " + option.desc
      });
      state.history = state.history.slice(0, 8);

      state.eventIndex += 1;
      if (state.eventIndex >= EVENTS.length) {
        state.ending = getEnding();
        state.scene = "ending";
      }
      render();
    }

    function getEnding() {
      const s = state.stats;
      const society = state.fairness;
      const wealth = s.bank + s.assets - s.debt;
      let title = "Stable Citizen Ending";
      let text = "You built a life with enough floor to stay standing and enough agency to matter. Not glamorous. Not broken. Real.";

      if (wealth > 160000 && s.power > 65) {
        title = "Elite Architect Ending";
        text = "You ended wealthy and influential. The question is whether your society worked because it was just, or because it worked for people like you.";
      } else if (wealth < -5000 && s.stress > 60) {
        title = "Debt Spiral Ending";
        text = "Small bad rolls, expensive systems, and thin buffers stacked into a life of constant recovery. This is exactly the outcome Rawls wants you to imagine before choosing institutions.";
      } else if (s.social > 72 && s.happiness > 60 && wealth < 90000) {
        title = "Community Builder Ending";
        text = "You may not have maximized money, but you built relationships, civic weight, and a life that mattered to other people.";
      } else if (s.health < 30) {
        title = "Burnout Survivor Ending";
        text = "You extracted a lot from yourself and the system extracted even more. You reached the ending, but not untouched.";
      } else if (s.assets > 70000 && state.flags.homeOwner) {
        title = "Property Ladder Ending";
        text = "You climbed through ownership. The system made assets a power-up, but mostly for players who could buy early.";
      } else if (society.fairness > 72 && s.happiness > 58) {
        title = "Fair Society Win";
        text = "Your world distributed risk decently, and your life showed it. You still faced randomness, but the floor held.";
      }

      const rawlsVerdict = society.fairness >= 65 && society.safety >= 60
        ? "A Rawlsian would likely say your society gave the least advantaged a fighting chance."
        : "A Rawlsian would likely ask why the least advantaged had to absorb this much risk.";

      return {
        title,
        text,
        wealth,
        rawlsVerdict,
        reroll: state.player.band,
        societyScore: society.overall
      };
    }

    function metricTemplate(key, value) {
      const meta = METRICS[key];
      const fill = meta.kind === "money" ? scorePercent(Math.max(0, value), meta.max) : scorePercent(value, meta.max);
      return `
        <div class="metric">
          <div class="metric-head"><span>${meta.icon} ${meta.label}</span><strong>${metricValue(key, value)}</strong></div>
          <div class="bar-shell"><div class="bar-fill" style="width:${fill}%"></div></div>
        </div>
      `;
    }

    function impactTemplate(effects) {
      return Object.entries(effects || {}).map(([key, delta]) => {
        const positive = delta >= 0;
        const sign = positive ? "+" : "";
        const label = METRICS[key].label;
        const val = METRICS[key].kind === "money" ? sign + money(delta) : sign + delta;
        return `<span class="impact ${positive ? "up" : "down"}">${label} ${val}</span>`;
      }).join("");
    }

    function optionTemplate(option, idx) {
      const lockedReason = optionLocked(option);
      const chance = Math.round(adjustedChance(option.chance || 1) * 100);
      return `
        <button class="option ${lockedReason ? "locked" : ""}" data-action="choose" data-index="${idx}">
          <div class="option-top">
            <div class="option-title">${option.label}</div>
            <div class="chance">${chance}% est.</div>
          </div>
          <div class="muted" style="font-size:13px; line-height:1.45;">${option.desc}</div>
          <div class="impact-row">${impactTemplate(option.effects)}</div>
          ${lockedReason ? `<div class="lock-note">🔒 <span>${lockedReason}</span></div>` : ""}
        </button>
      `;
    }

    function heroPixels() {
      const grid = [
        "0,1,hair","1,1,hair","2,1,hair","3,1,hair","4,1,hair",
        "1,2,hair","2,2,skin","3,2,skin","4,2,hair",
        "1,3,skin","2,3,skin","3,3,skin","4,3,skin",
        "1,4,shirt","2,4,shirt","3,4,shirt","4,4,shirt",
        "1,5,shirt","2,5,shirt","3,5,shirt","4,5,shirt",
        "1,6,pants","2,6,pants","3,6,pants","4,6,pants",
        "1,7,shoe","2,7,shoe","3,7,shoe","4,7,shoe",
        "5,1,spark","5,2,spark"
      ];
      const cells = [];
      for (let y = 1; y <= 7; y++) {
        for (let x = 0; x <= 5; x++) {
          const entry = grid.find((item) => item.startsWith(x + "," + y + ","));
          const klass = entry ? entry.split(",")[2] : "";
          cells.push(`<span class="px ${klass}"></span>`);
        }
      }
      return `<div class="pixel">${cells.join("")}</div>`;
    }

