                    <span class="pill">Education 5</span>
                    <span class="pill">Healthcare 5</span>
                    <span class="pill">Welfare 4</span>
                    <span class="pill">Housing 5</span>
                  </div>
                </div>
                <div class="world-grid">
                  ${configCard("tax", "Tax Rate", TAX_LEVELS, state.env.tax)}
                  ${configCard("education", "Education", EDUCATION_LEVELS, state.env.education)}
                  ${configCard("healthcare", "Healthcare", HEALTHCARE_LEVELS, state.env.healthcare)}
                  ${configCard("welfare", "Welfare", WELFARE_LEVELS, state.env.welfare)}
                  ${configCard("housing", "Housing", HOUSING_LEVELS, state.env.housing)}
                  ${configCard("labor", "Labor Rules", LABOR_LEVELS, state.env.labor)}
                  ${configCard("policing", "Policing / Surveillance", POLICING_LEVELS, state.env.policing)}
                </div>
              </div>
              <div class="builder-right">
                <div class="preview-stack card glass">
                  <div style="display:flex; justify-content:space-between; align-items:center; gap:10px;">
                    <div>
                      <h3 style="font-size:22px;">Society score</h3>
                      <div class="muted" style="font-size:13px;">You can see the world you are creating before the roulette wheel spins.</div>
                    </div>
                    <div class="big-score" style="font-size:34px;">${society.overall}</div>
                  </div>
                  ${renderPreviewBars(society)}
                </div>
                <div class="map-card card glass">
                  <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                    <h3 style="font-size:18px;">Live map preview</h3>
                    <span class="tag">Your avatar appears after the world lock</span>
                  </div>
                  ${mapTemplate("cityhall")}
                </div>
                <div class="score-box">
                  <div class="muted" style="font-size:12px; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:6px;">Build readout</div>
                  <div class="tag-row">
                    <span class="tag">Floor: ${society.safety >= 65 ? "Strong" : society.safety >= 40 ? "Medium" : "Weak"}</span>
                    <span class="tag">Mobility: ${society.opportunity >= 65 ? "High" : society.opportunity >= 40 ? "Mixed" : "Low"}</span>
                    <span class="tag">Chaos: ${society.volatility >= 65 ? "High" : society.volatility >= 40 ? "Medium" : "Low"}</span>
                    <span class="tag">Asset game: ${society.assetAccess >= 65 ? "Open" : society.assetAccess >= 40 ? "Partial" : "Hard"}</span>
                  </div>
                </div>
                <div class="footer-actions">
                  <button class="btn btn-secondary" data-action="back-title">Back</button>
                  <button class="btn btn-primary" data-action="lock-world">Lock the Constitution</button>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderBirth() {
      return `
        <div class="shell">
          <div class="screen">
            <div class="birth-layout">
              <div class="birth-left card glass">
                <div class="eyebrow">Spawn Reveal</div>
                <div class="birth-name">${state.player.name}</div>
                <div style="font-size:18px; color:#dce7ff;">Born in ${state.player.place}, ${state.player.country}</div>
                <p class="lead" style="font-size:17px; max-width:60ch;">${state.spawn.subhead} The game places you in the <strong>${state.player.band}</strong>, ${state.player.archetype}.</p>
                <div class="birth-grid">
                  <div class="info-chip"><small>Population placement</small><strong>${state.player.band}</strong></div>
                  <div class="info-chip"><small>Birth percentile roll</small><strong>${state.player.percentile}</strong></div>
                  <div class="info-chip"><small>Society score</small><strong>${state.fairness.overall}</strong></div>
                  <div class="info-chip"><small>Rawls challenge</small><strong>Would you still pick this world?</strong></div>
                </div>
                <div class="footer-actions">
                  <button class="btn btn-secondary" data-action="back-builder">Rebuild World</button>
                  <button class="btn btn-primary" data-action="begin-life">Live This Life</button>
                </div>
              </div>
              <div class="preview-panel card glass">
                <div class="map-card card" style="padding:10px; min-height:300px;">
                  <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                    <h3 style="font-size:18px;">Your first map</h3>
                    <span class="tag">${state.player.place}</span>
                  </div>
                  ${mapTemplate("home")}
                </div>
                <div class="metrics-grid" style="grid-template-columns:1fr 1fr;">
                  ${Object.entries(state.stats).map(([key, value]) => metricTemplate(key, value)).join("")}
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderPlay() {
      const event = currentEvent();
      const progress = Math.round((state.eventIndex / EVENTS.length) * 100);
      return `
        <div class="shell">
          <div class="screen">
            <div class="play-layout">
              <div class="hud">
                <div class="hud-card card glass">
                  <div>
                    <div class="muted" style="font-size:12px; text-transform:uppercase; letter-spacing:0.08em;">Life Stage</div>
                    <div class="hud-value">${event.stage}</div>
                  </div>
                  <div class="pill">Age ${event.age}</div>
                </div>
                <div class="hud-card card glass">
                  <div>
                    <div class="muted" style="font-size:12px; text-transform:uppercase; letter-spacing:0.08em;">Progress</div>
                    <div class="hud-value">${state.eventIndex + 1} / ${EVENTS.length}</div>
                  </div>
                  <div style="width:44%;">
                    <div class="bar-shell"><div class="bar-fill" style="width:${progress}%"></div></div>
                  </div>
                </div>
                <div class="hud-card card glass">
                  <div>
                    <div class="muted" style="font-size:12px; text-transform:uppercase; letter-spacing:0.08em;">Spawn Band</div>
                    <div class="hud-value" style="font-size:22px;">${state.player.band}</div>
                  </div>
                  <div class="pill">${state.player.place}</div>
                </div>
              </div>
              <div class="main-grid">
                <div class="column">
                  <div class="panel card glass">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                      <h3 style="font-size:18px;">World map</h3>
                      <span class="tag">Current zone: ${LANDMARKS[event.location].label}</span>
                    </div>
                    ${mapTemplate(event.location)}
                  </div>
                </div>
                <div class="column">
                  <div class="panel card glass" style="flex:1.05;">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                      <h3 style="font-size:18px;">Character sheet</h3>
                      <span class="tag">${state.player.name}</span>
                    </div>
                    <div class="metrics-grid">${Object.entries(state.stats).map(([key, value]) => metricTemplate(key, value)).join("")}</div>
                  </div>
                  <div class="panel card glass" style="flex:0.95;">
                    <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                      <h3 style="font-size:18px;">Story log</h3>
                      ${state.lastResult ? `<span class="tag">${state.lastResult.success ? "Last move landed" : "Last move failed"}</span>` : `<span class="tag">No move yet</span>`}
                    </div>
                    <div class="history-list">${state.history.map(item => `<div class="history-item"><small>Age ${item.age} • ${item.title}</small>${item.text}</div>`).join("")}</div>
                  </div>
                </div>
                <div class="column">
                  <div class="decision-card card glass">
                    <div class="decision-header">
                      <div>
                        <div class="stage-tag">${event.stage}</div>
                        <h2 style="font-size:28px; margin-top:10px; letter-spacing:-0.04em;">${event.title}</h2>
                        <p class="muted" style="font-size:14px; line-height:1.55; margin-top:8px;">${event.text}</p>
                      </div>
                    </div>
                    <div class="npc-box">${event.npc}</div>
                    <div class="progress-wrap">
                      <div class="bar-label"><span>Life arc completion</span><strong>${progress}%</strong></div>
                      <div class="bar-shell"><div class="bar-fill" style="width:${progress}%"></div></div>
                    </div>
                    <div class="options">
                      ${event.options.map((option, idx) => optionTemplate(option, idx)).join("")}
                    </div>
                    <div class="muted" style="font-size:12px; line-height:1.5;">Every option shows visible impact. Some are locked by your society settings, earlier decisions, or your current stats. Success odds also shift with your build.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function renderEnding() {
      const end = state.ending;
      return `
        <div class="shell">
          <div class="screen">
            <div class="ending-layout">
              <div class="ending-left card glass">
                <div class="eyebrow">Endgame • Rawls Reflection</div>
                <div class="ending-title">${end.title}</div>
                <p class="lead" style="font-size:17px; max-width:58ch;">${end.text}</p>
                <div class="ending-grid">
                  <div class="info-chip"><small>Final wealth</small><strong>${money(end.wealth)}</strong></div>
                  <div class="info-chip"><small>Society score</small><strong>${end.societyScore}</strong></div>
                  <div class="info-chip"><small>Spawn band</small><strong>${end.reroll}</strong></div>
                  <div class="info-chip"><small>Player</small><strong>${state.player.name}</strong></div>
                </div>
                <div class="reflection">
                  <strong>Rawls reflection:</strong><br /><br />
                  ${end.rawlsVerdict}<br /><br />
                  The whole point of the veil of ignorance is that you choose institutions before you know whether you will be rich or poor, healthy or sick, connected or isolated. Your run forced you to live inside the rules you created.
                </div>
                <div class="footer-actions">
                  <button class="btn btn-primary" data-action="restart">Play Again</button>
                  <button class="btn btn-secondary" data-action="back-builder">Rebuild Society</button>
                </div>
              </div>
              <div class="preview-panel card glass">
                <div class="map-card card" style="padding:10px; min-height:300px;">
                  <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
                    <h3 style="font-size:18px;">Your final map</h3>
                    <span class="tag">Full life completed</span>
                  </div>
                  ${mapTemplate("park")}
                </div>
                <div class="list">
                  <div><strong>Question 1:</strong> Would you accept this exact society if the game re-randomized your birth tomorrow?</div>
                  <div><strong>Question 2:</strong> Did the least advantaged in your world get a meaningful floor, or only survival?</div>
                  <div><strong>Question 3:</strong> Which setting changed outcomes most: taxes, welfare, housing, education, healthcare, labor, or policing?</div>
                  <div><strong>Question 4:</strong> Which of your late-game advantages came from merit, and which came from your initial spawn and system design?</div>
                </div>
                <div class="metrics-grid" style="grid-template-columns:1fr 1fr;">${Object.entries(state.stats).map(([key, value]) => metricTemplate(key, value)).join("")}</div>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    function render() {
      if (state.scene === "title") app.innerHTML = renderTitle();
      if (state.scene === "builder") app.innerHTML = renderBuilder();
      if (state.scene === "birth") app.innerHTML = renderBirth();
      if (state.scene === "play") app.innerHTML = renderPlay();
      if (state.scene === "ending") app.innerHTML = renderEnding();
    }

    app.addEventListener("click", (event) => {
      const target = event.target.closest("[data-action]");
      if (!target) return;
      const action = target.dataset.action;
      if (action === "goto-builder") {
        state.scene = "builder";
        render();
      }
      if (action === "back-title") {
        state.scene = "title";
        render();
      }
      if (action === "back-builder") {
        state.scene = "builder";
        render();
      }
      if (action === "set-env") {
        state.env[target.dataset.key] = Number(target.dataset.value);
        render();
      }
      if (action === "quick-random") {
        state.env = {
          tax: Math.floor(Math.random() * 10),
          education: Math.floor(Math.random() * 5),
          healthcare: Math.floor(Math.random() * 5),
          welfare: Math.floor(Math.random() * 4),
          housing: Math.floor(Math.random() * 5),
          labor: Math.floor(Math.random() * 5),
          policing: Math.floor(Math.random() * 5)
        };
        state.scene = "builder";
        render();
      }
      if (action === "lock-world") {
        spawnPlayer();
        state.scene = "birth";
        render();
      }
      if (action === "begin-life") {
        state.scene = "play";
        render();
      }
      if (action === "choose") {
        chooseOption(Number(target.dataset.index));
      }
      if (action === "restart") {
        resetGame();
      }
    });

    render();
  </script>
</body>
</html>
